# Copy to .env.local for local dev. In Vercel, set these in Project Settings → Environment Variables.

# Supabase Postgres connection string.
# IMPORTANT: Use the *Transaction pooler* (port 6543) for serverless / Vercel.
# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction".
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Secret used to sign session cookies (32+ random bytes, hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-me"

# Server timezone for admin password derivation (YYMMDD). PRD §2.3 / §5.6.
TZ="Asia/Seoul"
